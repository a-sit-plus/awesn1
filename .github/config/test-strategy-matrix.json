{
  "include": [
    {
      "os": "ubuntu-latest",
      "name": "spotlessCheck",
      "testCommand": "./gradlew spotlessCheck"
    },{
      "os": "ubuntu-latest",
      "name": "linuxNativeRunner",
      "testCommand": "./gradlew linuxX64Test --scan"
    },
    {
      "os": "macos-latest",
      "name": "jvmRunner",
      "testCommand": "./gradlew jvmTest --scan"
    },
    {
      "os": "ubuntu-latest",
      "name": "androidRunner",
      "enableKvm": false,
      "testCommand": "./gradlew pixelAVDAndroidDeviceTest --scan"
    },
    {
      "os": "ubuntu-latest",
      "name": "jsRunner",
      "testCommand": "NODE_OPTIONS=\"--max-old-space-size=8192\" ./gradlew jsTest --scan"
    },
    {
      "os": "windows-latest",
      "name": "mingwRunner",
      "testCommand": "./gradlew mingwX64Test --scan"
    },
    {
      "os": "macos-latest",
      "name": "iosRunner",
      "testCommand": "./gradlew iosArm64MainKlibrary iosSimulatorArm64MainKlibrary iosSimulatorArm64Test --scan"
    },
    {
      "os": "macos-latest",
      "name": "appleOtherRunner",
      "testCommand": "./gradlew tvosSimulatorArm64Test watchosSimulatorArm64Test macosArm64Test --scan"
    },
    {
      "os": "macos-latest",
      "name": "macRunner",
      "testCommand": "./gradlew allTests -x iosX64Test -x iosSimulatorArm64Test -x jvmTest -x jsTest --scan"
    }
  ]
}
